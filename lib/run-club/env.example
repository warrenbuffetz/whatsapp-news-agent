# Run Club apartment — add these to .env.local / Vercel alongside existing vars.

# Reused from main building
OPENWEATHER_API_KEY=
GEMINI_API_KEY=

# Telegram Bot API (https://core.telegram.org/bots#6-botfather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vercel Cron auth — Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
