# Copy this file to .env.local and fill in your credentials.
# .env.local is gitignored and used by Next.js locally and on Vercel (via dashboard).

# ── Twilio (WhatsApp Sandbox) ────────────────────────────────────────────────
# From https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Sandbox sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# Public URL of this webhook (required for signature validation in production).
# Local dev: use ngrok, e.g. https://abc123.ngrok.io/api/whatsapp
TWILIO_WEBHOOK_URL=

# ── OpenWeatherMap (free tier) ───────────────────────────────────────────────
# From https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Weather is fetched for Toronto, CA (hardcoded in lib/weather.ts)

# ── NewsAPI (free developer tier) ────────────────────────────────────────────
# From https://newsapi.org
# Note: free developer tier only works against localhost — use ngrok for local dev.
NEWS_API_KEY=

# ── Google Gemini ─────────────────────────────────────────────────────────────
# From https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model ID — Gemini 1.5 Flash (free tier compatible)
GEMINI_MODEL=gemini-1.5-flash
